    "quizData": [
        {
            "question": "Apa terjemahan yang tepat dari kalimat \"كَانَ الْوَلَدُ مَرِيْضًا\"?",
            "context": "كَانَ الْوَلَدُ مَرِيْضًا",
            "options": [
                "Anak itu sedang sakit sekarang",
                "Anak itu (dulu) sakit",
                "Anak itu akan sakit",
                "Sakit itu menimpa anak"
            ],
            "correctAnswer": 2,
            "explanation": "كَانَ adalah fi'il madhi naqish yang menunjukkan keadaan lampau. الْوَلَدُ adalah isim كَانَ (subjek) dan مَرِيْضًا adalah khabar كَانَ (predikat) yang manshub. Terjemahan yang tepat: \"Anak itu (dulu) sakit.\""
        },
        {
            "question": "Apa kedudukan kata \"الْجَوُّ\" dalam kalimat \"أَصْبَحَ الْجَوُّ بَارِدًا\"?",
            "context": "أَصْبَحَ الْجَوُّ بَارِدًا",
            "options": [
                "Khabar أَصْبَحَ manshub",
                "Fa'il marfu'",
                "Isim أَصْبَحَ marfu'",
                "Mubtada' marfu'"
            ],
            "correctAnswer": 3,
            "explanation": "الْجَوُّ berkedudukan sebagai isim أَصْبَحَ (اسم أصبح) yang marfu' dengan tanda dhammah. Dalam susunan كان وأخواتها, isimnya tetap marfu' sedangkan khabarnya manshub. أَصْبَحَ adalah saudara كَانَ yang bermakna 'menjadi di pagi hari'."
        },
        {
            "question": "Mengapa \"لَيْسَ\" termasuk dalam kelompok كَانَ وَأَخَوَاتُهَا?",
            "context": "لَيْسَ الْكَذِبُ مَحْمُوْدًا",
            "options": [
                "Karena ia fi'il mudhori'",
                "Karena ia huruf nafi'",
                "Karena ia fi'il naqish yang merafa'kan isim dan menashabkan khabar",
                "Karena ia selalu diikuti isim nakirah"
            ],
            "correctAnswer": 3,
            "explanation": "لَيْسَ adalah fi'il madhi naqish (tidak sempurna) yang termasuk أخوات كان. Disebut naqish karena tidak sempurna maknanya tanpa khabar. لَيْسَ merafa'kan isimnya dan menashabkan khabarnya, sama seperti كَانَ. Maknanya: 'tidak/bukan'."
        },
        {
            "question": "Apa tanda nashab pada khabar كَانَ dalam kalimat \"كَانَتِ الْمَدْرَسَةُ بَعِيْدَةً\"?",
            "context": "كَانَتِ الْمَدْرَسَةُ بَعِيْدَةً",
            "options": [
                "Dhammah",
                "Kasrah",
                "Fathah",
                "Wawu"
            ],
            "correctAnswer": 3,
            "explanation": "بَعِيْدَةً adalah khabar كَانَ yang manshub. Karena kata ini isim mufrad muannats, tanda nashabnya adalah fathah (ـً). Perlu diperhatikan bahwa كَانَتِ menggunakan ta' ta'nits karena isimnya (الْمَدْرَسَةُ) adalah muannats."
        },
        {
            "question": "Manakah yang merupakan perbedaan makna antara أَصْبَحَ dan أَمْسَى?",
            "context": "أَصْبَحَ الْجَوُّ بَارِدًا / أَمْسَى الطَّالِبُ تَعِبًا",
            "options": [
