    "quizData": [
        {
            "question": "Apa terjemahan yang tepat dari kalimat \"إِنَّ الْعِلْمَ نُوْرٌ\"?",
            "context": "إِنَّ الْعِلْمَ نُوْرٌ",
            "options": [
                "Ilmu adalah kegelapan",
                "Sesungguhnya cahaya adalah ilmu",
                "Sesungguhnya ilmu adalah cahaya",
                "Ilmu itu bukan cahaya"
            ],
            "correctAnswer": 3,
            "explanation": "إِنَّ adalah huruf taukid (penegasan) yang bermakna 'sesungguhnya'. Ia menashabkan isimnya (الْعِلْمَ) dan merafa'kan khabarnya (نُوْرٌ). Terjemahan yang tepat: \"Sesungguhnya ilmu adalah cahaya.\""
        },
        {
            "question": "Apa kedudukan kata \"الصِّدْقَ\" dalam kalimat \"أَنَّ الصِّدْقَ فَضِيْلَةٌ\"?",
            "context": "أَنَّ الصِّدْقَ فَضِيْلَةٌ",
            "options": [
                "Mubtada' marfu'",
                "Isim أَنَّ manshub",
                "Khabar أَنَّ marfu'",
                "Fa'il marfu'"
            ],
            "correctAnswer": 2,
            "explanation": "الصِّدْقَ berkedudukan sebagai isim أَنَّ yang manshub dengan tanda fathah. Kaidah إِنَّ وَأَخَوَاتُهَا: menashabkan isim dan merafa'kan khabar — kebalikan dari jumlah ismiyyah biasa. أَنَّ bermakna 'bahwa' dan biasa digunakan setelah fi'il atau dalam konstruksi mashdar."
        },
        {
            "question": "Apa makna khusus huruf \"لَكِنَّ\" dalam kalimat \"لَكِنَّ الْكَسُوْلَ خَاسِرٌ\"?",
            "context": "لَكِنَّ الْكَسُوْلَ خَاسِرٌ",
            "options": [
                "Penegasan (taukid)",
                "Penyerupaan (tasybih)",
                "Pengharapan (taraji)",
                "Pengecualian / pembetulan (istidrak)"
            ],
            "correctAnswer": 4,
            "explanation": "لَكِنَّ adalah huruf istidrak yang bermakna 'akan tetapi'. Ia berfungsi untuk membetulkan atau mengecualikan sesuatu dari pernyataan sebelumnya. Contoh penggunaan: 'Dia bekerja keras, akan tetapi orang malas itu merugi.' لَكِنَّ menashabkan isim dan merafa'kan khabar."
        },
        {
            "question": "Apa makna huruf \"كَأَنَّ\" dalam kalimat \"كَأَنَّ الْقَمَرَ مِصْبَاحٌ\"?",
            "context": "كَأَنَّ الْقَمَرَ مِصْبَاحٌ",
            "options": [
                "Sesungguhnya",
                "Semoga",
                "Seolah-olah / bagaikan",
                "Akan tetapi"
